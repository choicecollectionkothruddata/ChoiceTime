MONGODB_URI=your-mongodb-connection-string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
PORT=5000

# ParcelGuru — outbound API base URL (no trailing slash). Webhook verifies x-access-token against API key or webhook token.
PARCELGURU_BASE_URL=https://api.example-parcelguru.com
PARCELGURU_API_KEY=your-parcelguru-access-token
# Optional: if different from API key for webhook callbacks only
# PARCELGURU_WEBHOOK_TOKEN=

# Google OAuth (for "Continue with Google" - use Client ID from Google Cloud Console)
# Create OAuth 2.0 client at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
